{
  "name": "modulo",
  "version": "0.0.1",
  "description": "A lightweight, secure, open-source private npm registry built with TypeScript, Express 5, and a modern React UI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run build:ui",
    "build:ui": "cd ui && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:backend && npm run lint:ui",
    "lint:backend": "eslint 'src/**/*.ts'",
    "lint:ui": "cd ui && npm run lint",
    "lint:fix": "npm run lint:backend:fix && npm run lint:ui:fix",
    "lint:backend:fix": "eslint 'src/**/*.ts' --fix",
    "lint:ui:fix": "cd ui && npm run lint:fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crwblk/modulo.git"
  },
  "keywords": [
    "npm",
    "registry",
    "private",
    "packages",
    "express",
    "typescript"
  ],
  "author": "crwblk",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/crwblk/modulo/issues"
  },
  "homepage": "https://github.com/crwblk/modulo#readme",
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fs-extra": "^11.3.4",
    "helmet": "^8.1.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
